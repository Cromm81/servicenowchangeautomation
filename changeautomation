// ===== HELPER FUNCTIONS =====

/**
 * Get current month name
 * @returns {string} Month name (e.g., 'January')
 */
function getCurrentMonthName() {
  var monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];
  var now = new GlideDateTime();
  return monthNames[now.getMonthUTC()];
}

/**
 * Get Patch Tuesday (2nd Tuesday of the month)
 * @param {number} year - Full year (e.g., 2025)
 * @param {number} month - Month 1-12
 * @returns {GlideDateTime} Patch Tuesday date at midnight
 */
function getPatchTuesday(year, month) {
  var dateStr = year + '-' + (month < 10 ? '0' : '') + month + '-01 00:00:00';
  var date = new GlideDateTime(dateStr);
  var tuesdayCount = 0;
  
  // Find the 2nd Tuesday
  for (var i = 0; i < 31; i++) {
    if (date.getDayOfWeekLocalTime() === 3) { // 3 = Tuesday
      tuesdayCount++;
      if (tuesdayCount === 2) {
        return date;
      }
    }
    date.addDaysLocalTime(1);
  }
  
  return null; // Should never happen
}

/**
 * Calculate schedule (start and end dates/times) based on environment
 * @param {GlideDateTime} patchTuesday - The Patch Tuesday date
 * @param {object} template - Change template with schedule details
 * @returns {object} { startDate: 'yyyy-MM-dd HH:mm:ss', endDate: 'yyyy-MM-dd HH:mm:ss' }
 */
function calculateSchedule(patchTuesday, template) {
  var scheduleDate = new GlideDateTime(patchTuesday);
  var startDate, endDate;
  
  if (template.scheduleType === 'thursday') {
    // Thursday after Patch Tuesday
    var daysUntilThursday = (4 - scheduleDate.getDayOfWeekLocalTime() + 7) % 7;
    if (daysUntilThursday === 0) {
      daysUntilThursday = 7; // If today is Thursday, go to next Thursday
    }
    scheduleDate.addDaysLocalTime(daysUntilThursday);
  } else if (template.scheduleType === 'secondWeekend') {
    // 2nd Saturday after Patch Tuesday
    // Find next Saturday, then skip to 2nd Saturday
    var daysUntilSaturday = (7 - scheduleDate.getDayOfWeekLocalTime() + 7) % 7;
    if (daysUntilSaturday === 0) {
      daysUntilSaturday = 7; // If today is Saturday, go to next Saturday
    }
    scheduleDate.addDaysLocalTime(daysUntilSaturday);
    scheduleDate.addDaysLocalTime(7); // Add 7 days to get 2nd Saturday
  }
  
  // Get the date in proper format (YYYY-MM-DD)
  var dateString = scheduleDate.getLocalDate().toString(); // e.g., "2025-04-10"
  
  // Build start datetime string manually
  var startDateTimeStr = dateString + ' ' + template.startTime; // e.g., "2025-04-10 14:00:00"
  
  // Build end datetime string - add day offset if needed before constructing
  var endScheduleDate = new GlideDateTime(scheduleDate);
  if (template.endDateOffset) {
    endScheduleDate.addDaysLocalTime(template.endDateOffset);
  }
  var endDateString = endScheduleDate.getLocalDate().toString();
  var endDateTimeStr = endDateString + ' ' + template.endTime; // e.g., "2025-04-13 13:00:00"
  
  return {
    startDate: startDateTimeStr,
    endDate: endDateTimeStr
  };
}

/**
 * Create a change request record
 * @param {object} template - Change template with environment and schedule details
 * @param {object} schedule - Calculated schedule { startDate, endDate }
 * @returns {object} Insert result object
 */
function createChangeRequest(template, schedule) {
  var change = new GlideRecord('change_request');
  change.initialize();
  
  var monthName = getCurrentMonthName();
  
  // Apply all fields from FIELD_MAPPING, resolving dynamic values
  for (var fieldName in FIELD_MAPPING) {
    if (FIELD_MAPPING.hasOwnProperty(fieldName)) {
      var fieldValue = FIELD_MAPPING[fieldName];
      
      // Resolve dynamic fields
      if (fieldName === 'short_description' && fieldValue === null) {
        change[fieldName] = template.shortDesc + ' for ' + monthName;
      } else if (fieldName === 'description' && fieldValue === null) {
        change[fieldName] = template.description;
      } else if (fieldName === 'u_environment' && fieldValue === null) {
        change[fieldName] = template.environment;
      } else if (fieldName === 'start_date' && fieldValue === null) {
        change[fieldName] = schedule.startDate;
      } else if (fieldName === 'end_date' && fieldValue === null) {
        change[fieldName] = schedule.endDate;
      } else if (fieldValue !== null) {
        // Apply static fields
        change[fieldName] = fieldValue;
      }
    }
  }
  
  var result = change.insert();
  return {
    success: !!result,
    sysId: result,
    environment: template.environment,
    startDate: schedule.startDate,
    endDate: schedule.endDate
  };
}

// ===== MAIN EXECUTION =====

try {
  var now = new GlideDateTime();
  var year = now.getYearUTC();
  var month = now.getMonthUTC() + 1; // Convert 0-based to 1-based
  
  var patchTuesday = getPatchTuesday(year, month);
  
  if (!patchTuesday) {
    gs.error('Failed to calculate Patch Tuesday');
  } else {
    gs.info('Patch Tuesday calculated: ' + patchTuesday.getLocalDate().toString());
    
    var results = [];
    
    // Create a change request for each environment
    for (var i = 0; i < CHANGES.length; i++) {
      var template = CHANGES[i];
      var schedule = calculateSchedule(patchTuesday, template);
      var result = createChangeRequest(template, schedule);
      results.push(result);
      
      if (result.success) {
        gs.info('Created ' + result.environment + ' change request: ' + result.sysId);
        gs.info('  Start: ' + result.startDate);
        gs.info('  End: ' + result.endDate);
      } else {
        gs.error('Failed to create ' + result.environment + ' change request');
      }
    }
  }
} catch (e) {
  gs.error('Error in change request creation: ' + e.message);
}
